{
  "name": "ai-workspace-doctor",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform AI workspace environment scanner, repair profile generator, and desktop prototype.",
  "type": "module",
  "main": "electron/main.cjs",
  "bin": {
    "ai-doctor": "./cli/doctor.js"
  },
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:web": "vite --host 127.0.0.1 --port 5178",
    "start": "electron .",
    "build:web": "vite build",
    "scan": "node ./cli/doctor.js scan",
    "scan:json": "node ./cli/doctor.js scan --json",
    "fix:preview": "node ./cli/doctor.js fix --dry-run",
    "fix:write": "node ./cli/doctor.js fix --write"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "vite": "^7.2.7",
    "typescript": "^5.9.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "electron": "^39.2.7"
  },
  "devDependencies": {}
}
