{
  "name": "ai-workspace-doctor",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform AI workspace environment scanner, repair profile generator, and desktop prototype.",
  "type": "module",
  "main": "electron/main.cjs",
  "bin": {
    "ai-doctor": "./cli/doctor.js"
  },
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:web": "vite --host 127.0.0.1 --port 5178",
    "start": "electron .",
    "assets:icons": "node ./scripts/generate-icons.mjs",
    "build:web": "vite build",
    "pack:mac": "npm run build:web && electron-builder --mac dmg zip --publish never",
    "pack:mas": "npm run build:web && electron-builder --mac mas --publish never",
    "pack:win": "npm run build:web && electron-builder --win nsis zip --x64 --publish never",
    "pack:dir": "npm run build:web && electron-builder --dir --publish never",
    "scan": "node ./cli/doctor.js scan",
    "scan:json": "node ./cli/doctor.js scan --json",
    "fix:preview": "node ./cli/doctor.js fix --dry-run",
    "fix:write": "node ./cli/doctor.js fix --write"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "38.4.0",
    "electron-builder": "^26.15.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "author": {
    "name": "VoiceShell",
    "email": "support@voiceshell.ai"
  }
}
